#!/bin/bash

# slurm prolog script has no search path by default
# we also need to say "print" for stdout messages to go to the srun output
PATH=/usr/local/bin:/usr/bin:/bin:/home/ci/scopehal-ci-scripts/vm
if [ "$SLURM_NTASKS" -ne 1 ]; then
	echo "print Only single-node jobs are supported"
	exit 1;
fi

# VM configuration
NODE=$SLURM_JOB_NODELIST
VM_HOSTNAME=$NODE.cidmz.poulsbo.antikernel.net

#No VM stuff needed at all for postprocessing, that runs on the host
if [ "$NODE" == "postprocess" ]; then

exit;

#Special case the MacOS VM (and anything else that might later run on it)
elif [ "$NODE" == "macos" ]; then

	echo "print Starting worker node $NODE on mac mini...";

	# Set this as needed for $NODE
	TEMPLATE_NAME="ci-macos-baseline"
	RUNNER_NAME="ci-macos-runner"

	# NOTE: need to add app control permissions as described by alanb-sony https://github.com/utmapp/UTM/issues/5377
	# or this won't work
	MAC_HOST=cheddar.lab.poulsbo.antikernel.net
	ssh azonenberg@$MAC_HOST /usr/local/bin/utmctl clone $TEMPLATE_NAME --name $RUNNER_NAME
	ssh azonenberg@$MAC_HOST /usr/local/bin/utmctl start $RUNNER_NAME

# Default case: assume it's an xcp-ng VM
else
	VM_UUID=`get-vm-uuid $NODE` || (echo "invalid node ID"; exit 1;)

	# Spawn the worker VM
	echo "print Starting worker node $NODE...";
	xo-cli vm.start id=$VM_UUID > /dev/null
fi

# Wait for the VM to boot
wait-for-boot $NODE

# If this is the Arch runner, run an update and reboot cycle before doing anything else
# Otherwise vulkan seems to have problems sometimes with libraries not matching the kernel driver or something
if [ "$NODE" == "arch" ]; then

	# Patch it
	echo "print Installing package updates on $NODE...";
	ssh $VM_HOSTNAME sudo pacman -Syu --noconfirm --needed

	# Reboot it
	echo "print Shutting down $node..."
	VM_UUID=`get-vm-uuid $NODE` || (echo "invalid node ID"; exit 1;)
	xo-cli vm.stop id=$VM_UUID > /dev/null

	echo "print Restarting $NODE...";
	xo-cli vm.start id=$VM_UUID > /dev/null

	# Wait for the VM to boot for the second time
	wait-for-boot $NODE
fi
