#!/bin/bash
if [ "$#" -ne 1 ]; then
	echo "Usage: get-snapshot-uuid nodename"
	exit 1;
fi

case "$1" in
	"debian-stable")
		echo "974deb12-c5b8-4bf9-e8d3-3ec89862a036";;

	"debian-oldstable")
		echo "26014df7-612e-7ed4-4631-85101e458f2c";;

	"ubuntu-oldlts")
		echo "26925a3b-d6c5-e47b-dc89-ddaff5674b65";;

	*)
		echo "Invalid node name";
		exit 1;;
esac
