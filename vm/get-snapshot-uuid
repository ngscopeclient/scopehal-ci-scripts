#!/bin/bash
if [ "$#" -ne 1 ]; then
	echo "Usage: get-snapshot-uuid nodename"
	exit 1;
fi

case "$1" in
	"debian-stable")
		echo "48b9bc37-3c45-cf76-3268-0bdcbbb5101f";;

	"debian-oldstable")
		echo "61eb6f45-9d55-ab86-9e24-f6fe2314fd77";;

	"ubuntu-oldlts")
		echo "26925a3b-d6c5-e47b-dc89-ddaff5674b65";;

	*)
		echo "Invalid node name";
		exit 1;;
esac
