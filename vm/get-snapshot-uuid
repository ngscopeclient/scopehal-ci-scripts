#!/bin/bash
if [ "$#" -ne 1 ]; then
	echo "Usage: get-snapshot-uuid nodename"
	exit 1;
fi

case "$1" in
	"arch")
		echo "25b862f3-a2fe-7017-be09-1b72aab1fcb0";;

	"debian-stable")
		echo "bc71f5f8-b6e4-55dc-1f42-6fab85673e1b";;

	"debian-oldstable")
		echo "64adbc10-f666-76c2-5ebd-3ec8f6d7b61f";;

	"fedora")
		echo "178af0f9-f7d6-dd8a-e03e-ab9d0191e13d";;

	"ubuntu-lts")
		echo "346a7ae8-44a7-8224-952d-7c98eab4997e";;

	"ubuntu-oldlts")
		echo "3a52004b-6592-1201-e7a6-fe0fa562a4c6";;

	"win11")
		echo "eb224fa0-eed4-72c2-01d4-f8005bf9388f";;

	*)
		echo "Invalid node name";
		exit 1;;
esac
