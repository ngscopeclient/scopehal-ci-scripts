#!/bin/bash
if [ "$#" -ne 1 ]; then
	echo "Usage: get-snapshot-uuid nodename"
	exit 1;
fi

case "$1" in
	"debian-stable")
		echo "f94cce32-df0f-5782-f51b-4564f61110a7";;

	"debian-oldstable")
		echo "a1c95537-23d7-8188-ded9-fc7c2bde81c6";;

	"ubuntu-oldlts")
		echo "bc3bda9e-903e-0122-fddb-86418f0e59e2";;

	*)
		echo "Invalid node name";
		exit 1;;
esac
