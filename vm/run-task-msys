#!/bin/bash

if [ "$#" -ne 1 ]; then
	echo "Usage: run-task script.sh"
	exit 1;
fi

# VM configuration
VM_HOSTNAME=$SLURM_JOB_NODELIST.cidmz.poulsbo.antikernel.net

# Update msys2 on the VM first, this may kill the shell so run it twice to make sure we got everything
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
echo "--- Deploy update script ---"
scp $SCRIPT_DIR/msys-update.sh $VM_HOSTNAME:c:\\users\\ci\\update.sh
echo "--- Update msys2, first pass ---"
ssh $VM_HOSTNAME c:\\msys64\\msys2_shell.cmd -defterm -no-start -ucrt64 -c ./update.sh
echo "--- Update msys2, second pass ---"
ssh $VM_HOSTNAME c:\\msys64\\msys2_shell.cmd -defterm -no-start -ucrt64 -c ./update.sh

# Copy the job to the VM then run it
PAYLOAD=$1
echo "--- Deploy test script ---"
scp $PAYLOAD $VM_HOSTNAME:c:\\users\\ci\\payload.sh
echo "--- Run test script ---"
ssh $VM_HOSTNAME c:\\msys64\\msys2_shell.cmd -defterm -no-start -ucrt64 -c ./payload.sh
