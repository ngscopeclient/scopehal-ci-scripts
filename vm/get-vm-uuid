#!/bin/bash
if [ "$#" -ne 1 ]; then
	echo "Usage: get-vm-uuid nodename"
	exit 1;
fi

# updated 2026-04-11 for new UUIDs
case "$1" in
	"debian-stable")
		echo "9b78594a-b9d3-09cf-6e28-4d9ec6d72077";;

	"debian-oldstable")
		echo "ca3722cc-8fa0-355c-c6c9-b8ef8b7f4d0f";;

	"ubuntu-oldlts")
		echo "81d8224d-c35a-ec9c-5a7f-34dd4c40867f";;

	*)
		echo "Invalid node name";
		exit 1;;
esac
