#!/bin/bash
if [ "$#" -ne 1 ]; then
	echo "Usage: get-vm-uuid nodename"
	exit 1;
fi

case "$1" in
	"debian-stable")
		echo "0eb7e74a-c07d-aa43-75b9-d6c908a32007";;

	"debian-oldstable")
		echo "58185eec-5c2c-2c1b-fcab-d58cadfc22ca";;

	"ubuntu-oldlts")
		echo "ba751860-26c1-f801-9ab4-5b8b76bca454";;

	*)
		echo "Invalid node name";
		exit 1;;
esac
